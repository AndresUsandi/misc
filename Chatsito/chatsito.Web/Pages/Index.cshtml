@page
@model IndexModel
@{
    ViewData["Title"] = "Chatsito - AI Web Client";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

@Html.AntiForgeryToken()

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<div class="chat-app-container">
    <div class="chat-sidebar" id="chatSidebar">
        <div class="sidebar-header">
            <span class="logo-text">Chatsito</span>
            <span class="version-badge">Chatsito v0.1</span>
        </div>

        <div class="sidebar-info" style="margin-bottom: 20px;">
            <h3>Active Model</h3>
            <div class="model-select-wrapper" style="margin-top: 8px;">
                <select class="model-select" id="webModelSelect" onchange="handleSettingsChange()" style="width: 100%; background: var(--bg-input); color: var(--color-text-primary); border: 1px solid var(--border-glass); border-radius: 8px; padding: 10px; font-family: var(--font-primary); font-size: 13px; outline: none; cursor: pointer;">
                    @if (Model.AvailableModels != null)
                    {
                        @foreach (var modelItem in Model.AvailableModels)
                        {
                            if (modelItem == Model.SelectedModel)
                            {
                                <option value="@modelItem" selected="selected">@modelItem</option>
                            }
                            else
                            {
                                <option value="@modelItem">@modelItem</option>
                            }
                        }
                    }
                </select>
            </div>
        </div>

        <div class="checkbox-wrapper" style="margin-bottom: 20px; padding: 0 16px;">
            <label style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--color-text-secondary); cursor: pointer;">
                <input type="checkbox" id="showThinkingCheckbox" style="accent-color: #a855f7;" onchange="handleSettingsChange()" @(Model.IncludeThinking ? "checked" : "")>
                Include thinking
            </label>
        </div>

        <form method="post" asp-page-handler="Clear" class="clear-form">
            <button type="submit" class="btn btn-clear-history">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3" viewBox="0 0 16 16">
                  <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5"/>
                </svg>
                Clear History
            </button>
        </form>
    </div>

    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <div class="chat-main-window">
        <div class="chat-header">
            <button class="hamburger-menu" id="hamburgerMenu" onclick="toggleSidebar()">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
            <span class="chat-header-title">Chatsito</span>
        </div>

        <div class="chat-history-container" id="chatHistory">
            @if (Model.ConversationHistory == null || Model.ConversationHistory.Count == 0)
            {
                <div class="empty-chat-state" id="emptyChatState">
                    <div class="ai-sparkle-icon">✦</div>
                    <h2>How can I help you today?</h2>
                    <p>Chatsito is here for you!</p>
                </div>
            }
            else
            {
                @foreach (var message in Model.ConversationHistory)
                {
                    if (message.Role == chatsito.Core.Role.Tool) { continue; }
                    if (message.Role == chatsito.Core.Role.Assistant && message.ToolCalls != null && message.ToolCalls.Any()) { continue; }

                    var isUser = message.Role == chatsito.Core.Role.User;
                    <div class="message-wrapper @(isUser ? "user-wrapper" : "assistant-wrapper")">
                        <div class="message-bubble @(isUser ? "user-bubble" : "assistant-bubble")">
                            <div class="message-meta">
                                <span class="sender-name">@(isUser ? "You" : "Chatsito")</span>
                            </div>
                            <div class="message-text">@message.Content</div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="chat-input-panel">
            <form id="chatForm" onsubmit="handleChatSubmit(event)">
                <div class="input-group-wrapper">
                    <textarea 
                        asp-for="Prompt" 
                        class="chat-textarea" 
                        placeholder="Type a message to Chatsito..." 
                        rows="1" 
                        id="promptInput"
                        onkeydown="submitOnEnter(event)"></textarea>
                    <button type="submit" class="btn btn-send" id="sendBtn">
                        <span class="btn-text">Send</span>
                        <svg class="send-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22 2L11 13M22 2L15 22L11 13M11 13L2 9L22 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    :root {
        --font-primary: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        --font-display: 'Outfit', sans-serif;
        --bg-main: #ffffff;
        --bg-sidebar: #e0f2fe;
        --bg-card: #f0f9ff;
        --bg-input: #ffffff;
        --border-glass: rgba(116, 172, 223, 0.3);
        --color-text-primary: #1e3a8a;
        --color-text-secondary: #3b82f6;
        --accent-purple-gradient: linear-gradient(135deg, #74ACDF 0%, #3b82f6 100%);
        --accent-glow: 0 0 20px rgba(116, 172, 223, 0.35);
        --color-gold: #F6B40E;
        --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    html, body {
        height: 100%;
        margin: 0;
        padding: 0;
    }

    body {
        background-color: var(--bg-main);
        color: var(--color-text-primary);
        font-family: var(--font-primary);
        overflow: hidden;
    }

    .chat-app-container {
        display: flex;
        height: 100%;
        width: 100%;
    }

    /* Sidebar Styling */
    .chat-sidebar {
        width: 280px;
        background-color: var(--bg-sidebar);
        border-right: 1px solid var(--border-glass);
        display: flex;
        flex-direction: column;
        padding: 24px;
        box-sizing: border-box;
    }

    .sidebar-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 40px;
    }

    .logo-text {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 24px;
        background: var(--accent-purple-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -0.5px;
    }

    .version-badge {
        font-size: 10px;
        background: rgba(246, 180, 14, 0.15);
        color: #d97706;
        padding: 2px 8px;
        border-radius: 9999px;
        border: 1px solid rgba(246, 180, 14, 0.25);
        font-weight: 600;
    }

    .sidebar-info {
        background: var(--bg-card);
        border: 1px solid var(--border-glass);
        padding: 16px;
        border-radius: 16px;
        margin-bottom: auto;
    }

    .sidebar-info h3 {
        margin-top: 0;
        margin-bottom: 12px;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--color-text-secondary);
        font-weight: 700;
    }

    .status-indicator {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 600;
        font-size: 14px;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        background-color: #10b981;
        border-radius: 50%;
        box-shadow: 0 0 8px #10b981;
    }

    .status-desc {
        font-size: 12px;
        color: var(--color-text-secondary);
        margin-top: 8px;
        margin-bottom: 0;
        line-height: 1.4;
    }

    /* Main Window */
    .chat-main-window {
        flex: 1;
        display: flex;
        flex-direction: column;
        height: 100%;
        position: relative;
    }

    /* Chat History */
    .chat-history-container {
        flex: 1;
        overflow-y: auto;
        padding: 32px;
        display: flex;
        flex-direction: column;
        gap: 24px;
        scrollbar-width: thin;
        scrollbar-color: rgba(255, 255, 255, 0.1) transparent;
    }

    .chat-history-container::-webkit-scrollbar {
        width: 6px;
    }

    .chat-history-container::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 999px;
    }

    /* Empty State */
    .empty-chat-state {
        margin: auto;
        text-align: center;
        max-width: 480px;
        display: flex;
        flex-direction: column;
        align-items: center;
        animation: fadeIn 0.6s ease-out;
    }

    .ai-sparkle-icon {
        font-size: 48px;
        background: linear-gradient(135deg, var(--color-gold) 0%, #d97706 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 24px;
        filter: drop-shadow(0 0 10px rgba(246, 180, 14, 0.5));
        animation: pulse 2s infinite ease-in-out;
    }

    .empty-chat-state h2 {
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 28px;
        margin-top: 0;
        margin-bottom: 12px;
        letter-spacing: -0.5px;
    }

    .empty-chat-state p {
        color: var(--color-text-secondary);
        font-size: 15px;
        line-height: 1.6;
        margin: 0;
    }

    /* Messages bubble design */
    .message-wrapper {
        display: flex;
        width: 100%;
    }

    .user-wrapper {
        justify-content: flex-end;
    }

    .assistant-wrapper {
        justify-content: flex-start;
    }

    .message-bubble {
        max-width: 70%;
        padding: 16px 20px;
        border-radius: 20px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        position: relative;
        animation: popIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .user-bubble {
        background: var(--accent-purple-gradient);
        color: white;
        border-bottom-right-radius: 4px;
    }

    .assistant-bubble {
        background: var(--bg-card);
        border: 1px solid var(--border-glass);
        color: var(--color-text-primary);
        border-bottom-left-radius: 4px;
    }

    .message-meta {
        margin-bottom: 6px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .user-bubble .message-meta {
        color: rgba(255, 255, 255, 0.7);
    }

    .assistant-bubble .message-meta {
        color: #d97706;
    }

    .message-text {
        font-size: 15px;
        line-height: 1.6;
    }

    .user-bubble .message-text {
        white-space: pre-wrap;
    }

    .assistant-bubble .message-text {
        white-space: normal;
    }

    .message-text p {
        margin-top: 0;
        margin-bottom: 12px;
    }

    .message-text p:last-child {
        margin-bottom: 0;
    }

    .message-text ul, .message-text ol {
        margin-top: 0;
        margin-bottom: 12px;
        padding-left: 24px;
    }

    .message-text li {
        margin-bottom: 6px;
    }

    .message-text pre {
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid var(--border-glass);
        padding: 14px;
        border-radius: 10px;
        overflow-x: auto;
        margin: 14px 0;
    }

    .message-text code {
        font-family: 'Consolas', 'Courier New', Courier, monospace;
        font-size: 0.9em;
        background: rgba(116, 172, 223, 0.1);
        padding: 2px 6px;
        border-radius: 6px;
        color: #1d4ed8;
    }

    .message-text pre code {
        background: transparent;
        padding: 0;
        color: inherit;
        border-radius: 0;
    }

    .thinking-group-wrapper {
        justify-content: flex-start;
        margin-bottom: 24px;
        width: 100%;
    }

    .thinking-group-details {
        width: 100%;
        max-width: 80%;
        background: rgba(254, 240, 138, 0.15); /* very light yellow/gold */
        border: 1px solid rgba(250, 204, 21, 0.3);
        border-radius: 16px;
        padding: 12px 20px;
    }

    .thinking-group-details summary {
        cursor: pointer;
        font-weight: 600;
        font-size: 13px;
        color: var(--color-text-secondary);
        display: flex;
        align-items: center;
        gap: 8px;
        outline: none;
        user-select: none;
    }

    .thinking-group-details summary::-webkit-details-marker {
        display: none;
    }

    .thinking-group-content {
        margin-top: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .inner-thinking-bubble {
        background: #fef9c3;
        border: 1px solid rgba(234, 179, 8, 0.4);
        color: #854d0e;
        font-style: italic;
        padding: 12px 16px;
        border-radius: 12px;
        font-size: 13px;
        transition: var(--transition-smooth);
    }
    
    .inner-thinking-bubble.tool-call-bubble {
        background: #fef08a; /* darker light yellow */
        border-color: #ca8a04;
        color: #422006; /* darker brown/gold */
        font-style: normal;
        font-family: 'Consolas', 'Courier New', Courier, monospace;
    }

    .inner-thinking-bubble pre {
        background: rgba(0, 0, 0, 0.05);
        border-color: rgba(0, 0, 0, 0.1);
        color: inherit;
    }
    
    .inner-thinking-bubble code {
        background: rgba(0, 0, 0, 0.05);
        color: inherit;
    }

    /* Loading / Sand Clock animation */
    .loading-wrapper {
        display: flex;
        justify-content: flex-start;
        align-items: center;
        gap: 12px;
        animation: fadeIn 0.3s ease-out;
    }

    .hourglass-loader {
        display: inline-block;
        position: relative;
        width: 20px;
        height: 20px;
    }

    .hourglass-loader:after {
        content: " ";
        display: block;
        border-radius: 50%;
        width: 0;
        height: 0;
        margin: 0px;
        box-sizing: border-box;
        border: 10px solid var(--color-gold);
        border-color: var(--color-gold) transparent var(--color-gold) transparent;
        animation: hourglass 1.4s infinite ease-in-out;
    }

    @@keyframes hourglass {
        0% {
            transform: rotate(0);
        }
        50% {
            transform: rotate(180deg);
        }
        100% {
            transform: rotate(360deg);
        }
    }

    .loading-text {
        font-size: 13px;
        color: var(--color-text-secondary);
        font-weight: 500;
    }

    /* Input Panel */
    .chat-input-panel {
        padding: 24px 32px 32px 32px;
        background: linear-gradient(180deg, rgba(10, 15, 29, 0) 0%, var(--bg-main) 40%);
    }

    .input-group-wrapper {
        max-width: 800px;
        margin: 0 auto;
        background: var(--bg-input);
        border: 1px solid var(--border-glass);
        border-radius: 20px;
        padding: 8px 8px 8px 18px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
        transition: var(--transition-smooth);
    }

    .input-group-wrapper:focus-within {
        border-color: #a855f7;
        box-shadow: var(--accent-glow);
    }

    .chat-textarea {
        flex: 1;
        background: transparent;
        border: none;
        color: var(--color-text-primary);
        font-family: var(--font-primary);
        font-size: 15px;
        outline: none;
        resize: none;
        padding: 4px 0;
        max-height: 120px;
        overflow-y: auto;
        height: 24px;
        line-height: 24px;
    }

    .chat-textarea::placeholder {
        color: var(--color-text-secondary);
        font-size: 13px;
    }

    /* Buttons */
    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: var(--font-primary);
        font-weight: 600;
        font-size: 14px;
        border: none;
        cursor: pointer;
        transition: var(--transition-smooth);
    }

    .btn-send {
        background: var(--accent-purple-gradient);
        color: white;
        border-radius: 14px;
        padding: 10px 20px;
    }

    .btn-send:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(168, 85, 247, 0.4);
    }

    .btn-send:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .send-icon {
        width: 16px;
        height: 16px;
    }

    .btn-clear-history {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #ef4444;
        border-radius: 12px;
        width: 100%;
        padding: 12px;
        margin-top: 12px;
    }

    .btn-clear-history:hover {
        background: #ef4444;
        color: white;
        transform: translateY(-1px);
    }

    /* Errors */
    .error-banner {
        display: flex;
        gap: 16px;
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #f87171;
        padding: 16px;
        border-radius: 16px;
        animation: popIn 0.3s ease-out;
    }

    .error-icon {
        font-size: 20px;
    }

    .error-content strong {
        display: block;
        font-size: 14px;
        margin-bottom: 4px;
    }

    .error-msg {
        font-size: 13px;
        margin: 0;
        opacity: 0.9;
    }

    /* Animations */
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes popIn {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1); opacity: 0.8; }
        50% { transform: scale(1.08); opacity: 1; }
    }

    /* Mobile responsive styling */
    .chat-header {
        display: none;
        align-items: center;
        padding: 16px 24px;
        background-color: var(--bg-sidebar);
        border-bottom: 1px solid var(--border-glass);
        gap: 16px;
    }

    .chat-header-title {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 18px;
        background: var(--accent-purple-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .hamburger-menu {
        background: transparent;
        border: none;
        color: var(--color-text-primary);
        cursor: pointer;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .sidebar-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
        z-index: 99;
    }

    @@media (max-width: 768px) {
        .chat-header {
            display: flex !important;
        }

        .chat-sidebar {
            position: fixed !important;
            top: 0;
            left: 0;
            bottom: 0;
            z-index: 100;
            transform: translateX(-100%) !important;
            transition: var(--transition-smooth);
            box-shadow: 10px 0 30px rgba(0, 0, 0, 0.5);
        }

        .chat-sidebar.active {
            transform: translateX(0) !important;
        }

        .chat-history-container {
            padding: 20px;
        }

        .message-bubble {
            max-width: 85%;
        }

        .chat-input-panel {
            padding: 16px 20px 24px 20px;
        }

        .input-group-wrapper {
            padding: 6px 6px 6px 14px;
        }

        .chat-textarea::placeholder {
            font-size: 11px;
        }
    }
</style>

<script>
    // Auto-scroll chat history to the bottom on load
    window.addEventListener('DOMContentLoaded', () => {
        // Parse existing assistant messages on page load
        document.querySelectorAll('.assistant-bubble .message-text').forEach(el => {
            el.innerHTML = marked.parse(el.textContent);
        });

        scrollToBottom();

        // Auto-resize textarea heights
        const textarea = document.getElementById('promptInput');
        textarea.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';
        });
    });

    function toggleSidebar() {
        const sidebar = document.getElementById('chatSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        sidebar.classList.toggle('active');
        
        if (sidebar.classList.contains('active')) {
            overlay.style.display = 'block';
        } else {
            overlay.style.display = 'none';
        }
    }

    function scrollToBottom() {
        const chatHistory = document.getElementById('chatHistory');
        chatHistory.scrollTop = chatHistory.scrollHeight;
    }

    function submitOnEnter(event) {
        if (event.key === 'Enter' && !event.shiftKey) {
            event.preventDefault();
            handleChatSubmit(event);
        }
    }

    async function handleChatSubmit(event) {
        event.preventDefault();
        
        const textarea = document.getElementById('promptInput');
        const promptText = textarea.value.trim();
        if (!promptText) return;

        // Clear textarea & reset height
        textarea.value = '';
        textarea.style.height = 'auto';

        // Get elements
        const chatHistory = document.getElementById('chatHistory');
        const emptyState = document.getElementById('emptyChatState');
        const sendBtn = document.getElementById('sendBtn');

        // Hide empty state if it exists
        if (emptyState) {
            emptyState.remove();
        }

        // Disable input and button
        textarea.disabled = true;
        sendBtn.disabled = true;

        // 1. Immediately append user message to the DOM
        appendUserMessage(promptText);
        scrollToBottom();

        // 2. Append animated hourglass loading indicator
        const loaderId = appendLoadingIndicator();
        scrollToBottom();

        // Get Anti-forgery token
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const modelVal = document.getElementById('webModelSelect')?.value || '';
        const includeThinking = document.getElementById('showThinkingCheckbox')?.checked || false;

        try {
            // 3. Perform AJAX request to ASP.NET Core Page Handler
            const response = await fetch('?handler=SendMessageStream', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ prompt: promptText, model: modelVal, includeThinking: includeThinking })
            });

            // Remove loading indicator
            document.getElementById(loaderId).remove();

            if (!response.ok) {
                const text = await response.text();
                appendErrorBanner(text || "An unknown error occurred.");
                return;
            }

            const reader = response.body.getReader();
            const decoder = new TextDecoder('utf-8');
            let buffer = "";
            let blocks = []; // Array to store { type, text, el }
            let thinkingGroup = null; // Container for all think segments
            const showThinking = document.getElementById('showThinkingCheckbox')?.checked;

            while (true) {
                const { value, done } = await reader.read();
                if (done) {
                    if (thinkingGroup && showThinking) {
                        thinkingGroup.details.open = false; // collapse when done
                    }
                    break;
                }
                
                const chunk = decoder.decode(value, { stream: true });
                buffer += chunk;
                
                let lines = buffer.split('\n');
                buffer = lines.pop(); // keep the last incomplete line in buffer

                for (let line of lines) {
                    if (!line.startsWith('data: ')) continue;
                    let jsonStr = line.substring(6).trim();
                    if (!jsonStr) continue;

                    let evt = null;
                    try {
                        evt = JSON.parse(jsonStr);
                    } catch (e) {
                        console.error("Failed to parse SSE JSON", e, jsonStr);
                        continue;
                    }

                    if (evt.type === 'reasoning') {
                        let lastBlock = blocks[blocks.length - 1];
                        if (!lastBlock || lastBlock.type !== 'reasoning') {
                            if (!thinkingGroup) {
                                thinkingGroup = createThinkingGroup(showThinking);
                                document.getElementById('chatHistory').appendChild(thinkingGroup.wrapper);
                            }
                            lastBlock = { type: 'reasoning', text: '', el: appendInnerThinkingMessage(thinkingGroup.content, "") };
                            blocks.push(lastBlock);
                        }
                        lastBlock.text += evt.content;
                        lastBlock.el.innerHTML = marked.parse(lastBlock.text);
                    } 
                    else if (evt.type === 'tool_call' || evt.type === 'tool_result') {
                        let lastBlock = blocks[blocks.length - 1];
                        if (!lastBlock || lastBlock.type !== 'tool') {
                            if (!thinkingGroup) {
                                thinkingGroup = createThinkingGroup(showThinking);
                                document.getElementById('chatHistory').appendChild(thinkingGroup.wrapper);
                            }
                            let el = appendInnerThinkingMessage(thinkingGroup.content, "");
                            el.classList.add('tool-call-bubble');
                            lastBlock = { type: 'tool', text: '', el: el };
                            blocks.push(lastBlock);
                        }
                        lastBlock.text += evt.content;
                        lastBlock.el.innerHTML = marked.parse(lastBlock.text);
                    } 
                    else if (evt.type === 'content') {
                        let lastBlock = blocks[blocks.length - 1];
                        if (!lastBlock || lastBlock.type !== 'content') {
                            lastBlock = { type: 'content', text: '', el: appendAssistantMessage("") };
                            blocks.push(lastBlock);
                        }
                        lastBlock.text += evt.content;
                        lastBlock.el.innerHTML = marked.parse(lastBlock.text);
                    } 
                    else if (evt.type === 'error') {
                        let el = appendAssistantMessage("");
                        el.innerHTML = marked.parse(evt.content);
                        blocks.push({ type: 'error', text: evt.content, el: el });
                    }
                }
                
                
                scrollToBottom();
            }
        } catch (error) {
            const loader = document.getElementById(loaderId);
            if (loader) loader.remove();
            appendErrorBanner(error.message || "Failed to communicate with the server.");
        } finally {
            // Re-enable inputs
            textarea.disabled = false;
            sendBtn.disabled = false;
            textarea.focus();
            scrollToBottom();
        }
    }

    function createThinkingGroup(showThinking) {
        const wrapper = document.createElement('div');
        wrapper.className = 'message-wrapper thinking-group-wrapper';
        if (!showThinking) wrapper.style.display = 'none';
        
        const details = document.createElement('details');
        details.className = 'thinking-group-details';
        details.open = true; // Open while streaming
        
        const summary = document.createElement('summary');
        summary.innerHTML = '<span class="ai-sparkle-icon">✦</span> Thinking Process <svg style="margin-left:auto;width:14px;height:14px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>';
        
        const content = document.createElement('div');
        content.className = 'thinking-group-content';
        
        details.appendChild(summary);
        details.appendChild(content);
        wrapper.appendChild(details);
        
        return { wrapper, details, content };
    }

    function appendInnerThinkingMessage(container, content) {
        const bubble = document.createElement('div');
        bubble.className = 'inner-thinking-bubble';
        bubble.innerHTML = marked.parse(content || 'Thinking...');
        container.appendChild(bubble);
        return bubble;
    }

    function appendUserMessage(content) {
        const chatHistory = document.getElementById('chatHistory');
        
        const wrapper = document.createElement('div');
        wrapper.className = 'message-wrapper user-wrapper';
        
        const bubble = document.createElement('div');
        bubble.className = 'message-bubble user-bubble';
        
        const meta = document.createElement('div');
        meta.className = 'message-meta';
        meta.innerHTML = '<span class="sender-name">You</span>';
        
        const text = document.createElement('div');
        text.className = 'message-text';
        text.textContent = content;

        bubble.appendChild(meta);
        bubble.appendChild(text);
        wrapper.appendChild(bubble);
        chatHistory.appendChild(wrapper);
    }

    function appendAssistantMessage(content) {
        const chatHistory = document.getElementById('chatHistory');
        
        const wrapper = document.createElement('div');
        wrapper.className = 'message-wrapper assistant-wrapper';
        
        const bubble = document.createElement('div');
        bubble.className = 'message-bubble assistant-bubble';
        
        const meta = document.createElement('div');
        meta.className = 'message-meta';
        meta.innerHTML = '<span class="sender-name">Chatsito</span>';
        
        const text = document.createElement('div');
        text.className = 'message-text';
        text.innerHTML = marked.parse(content);

        bubble.appendChild(meta);
        bubble.appendChild(text);
        wrapper.appendChild(bubble);
        chatHistory.appendChild(wrapper);

        return text;
    }

    function appendLoadingIndicator() {
        const chatHistory = document.getElementById('chatHistory');
        const id = 'loader_' + Date.now();

        const wrapper = document.createElement('div');
        wrapper.className = 'loading-wrapper';
        wrapper.id = id;

        const loader = document.createElement('span');
        loader.className = 'hourglass-loader';

        const text = document.createElement('span');
        text.className = 'loading-text';
        text.textContent = 'Chatsito is thinking...';

        wrapper.appendChild(loader);
        wrapper.appendChild(text);
        chatHistory.appendChild(wrapper);

        return id;
    }

    function appendErrorBanner(message) {
        const chatHistory = document.getElementById('chatHistory');

        const banner = document.createElement('div');
        banner.className = 'error-banner';

        const icon = document.createElement('div');
        icon.className = 'error-icon';
        icon.textContent = '⚠';

        const content = document.createElement('div');
        content.className = 'error-content';
        
        const strong = document.createElement('strong');
        strong.textContent = 'Error';

        const msg = document.createElement('p');
        msg.className = 'error-msg';
        msg.textContent = message;

        content.appendChild(strong);
        content.appendChild(msg);
        banner.appendChild(icon);
        banner.appendChild(content);
        chatHistory.appendChild(banner);
    }

    async function handleSettingsChange() {
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const modelVal = document.getElementById('webModelSelect')?.value || '';
        const includeThinking = document.getElementById('showThinkingCheckbox')?.checked || false;
        
        try {
            await fetch('?handler=ChangeSettings', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ model: modelVal, includeThinking: includeThinking })
            });
        } catch (err) {
            console.error("Failed to update settings on server", err);
        }
    }
</script>
