{
  "name": "chatsito-vscode",
  "displayName": "Chatsito",
  "description": "Visual Studio Code client for the Chatsito AI assistant.",
  "version": "0.1.0",
  "publisher": "AndresUsandi",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AndresUsandi/MachineLarning.git"
  },
  "activationEvents": [
    "onCommand:chatsito.openChat",
    "onCommand:chatsito.evaluateHumanEval",
    "onCommand:chatsito.evaluateLiveCodeBench",
    "onCommand:chatsito.evaluateSWEBench",
    "onView:chatsito.sidebarView"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "chatsito.openChat",
        "title": "Chatsito: Open Chat"
      },
      {
        "command": "chatsito.evaluateHumanEval",
        "title": "Chatsito: Evaluate with HumanEval"
      },
      {
        "command": "chatsito.evaluateLiveCodeBench",
        "title": "Chatsito: Evaluate with LiveCodeBench"
      },
      {
        "command": "chatsito.evaluateSWEBench",
        "title": "Chatsito: Evaluate with SWE-Bench"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chatsito-sidebar",
          "title": "Chatsito",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "chatsito-sidebar": [
        {
          "id": "chatsito.sidebarView",
          "name": "Chatsito Chat",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Chatsito",
      "properties": {
        "chatsito.logThinking": {
          "type": "boolean",
          "default": true,
          "description": "If enabled, Chatsito will request and log thinking/reasoning blocks from local reasoning models."
        }
      }
    }
  },
  "scripts": {
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "chai": "^6.2.2",
    "glob": "^13.0.6",
    "mocha": "^11.7.6"
  }
}
